# ============================================================
# Drwintech Fleet — variables d'environnement (exemple)
# Copier en .env (jamais commité) et adapter.
# ============================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Base métier (PostgreSQL) ---
DB_NAME=fleet
DB_USER=fleet
DB_PASSWORD=fleet
DB_HOST=localhost
DB_PORT=5440

# --- Base télémétrie (TimescaleDB) ---
TSDB_NAME=fleet_telemetry
TSDB_USER=fleet
TSDB_PASSWORD=fleet
TSDB_HOST=localhost
TSDB_PORT=5434

# --- Redis (cache / broker Celery / pub-sub) ---
REDIS_URL=redis://localhost:6381/0
CELERY_BROKER_URL=redis://localhost:6381/1

# --- Traccar (moteur d'ingestion) ---
TRACCAR_API_URL=http://localhost:8082/api
TRACCAR_WS_URL=ws://localhost:8082/api/socket
TRACCAR_SERVICE_USER=service@drwintech.com
# Valeur entre quotes : le caractère # serait sinon traité comme un commentaire.
TRACCAR_SERVICE_PASSWORD='FleetSvc#2026'

# --- JWT ---
ACCESS_TOKEN_LIFETIME_MIN=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Métier ---
DEFAULT_CURRENCY=XOF
PAYMENT_GRACE_DAYS=7
SIM_LOW_BALANCE_THRESHOLD_PERCENT=20

# --- Agrégateurs de paiement (clés à obtenir) ---
GOBIPAY_API_KEY=
FEDAPAY_API_KEY=
NOTCHPAY_API_KEY=

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_DEFAULT_LOCALE=fr
