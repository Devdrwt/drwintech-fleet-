# ============================================================
# Drwintech Fleet — variables PRODUCTION (copier en .env sur le VPS).
# Générer les secrets (ne JAMAIS committer le .env réel).
# Les hôtes pointent vers les noms de services docker-compose.prod.yml.
# ============================================================

# --- Images (publiées par la CI sur GHCR) ---
BACKEND_IMAGE=ghcr.io/devdrwt/fleet_back:latest
FRONTEND_IMAGE=ghcr.io/devdrwt/fleet_front:latest

# --- Ports hôte (loopback ; proxifiés par le nginx du VPS) ---
API_HOST_PORT=8012
WEB_HOST_PORT=3001

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=__GENERER__
DEBUG=False
ALLOWED_HOSTS=api-fleet.drwintech.com
CSRF_TRUSTED_ORIGINS=https://api-fleet.drwintech.com,https://fleet.drwintech.com
CORS_ALLOWED_ORIGINS=https://fleet.drwintech.com

# --- Base métier (PostgreSQL, conteneur `postgres`) ---
DB_NAME=fleet
DB_USER=fleet
DB_PASSWORD=__GENERER__
DB_HOST=postgres
DB_PORT=5432

# --- Base télémétrie (TimescaleDB, conteneur `timescaledb`) ---
TSDB_NAME=fleet_telemetry
TSDB_USER=fleet
TSDB_PASSWORD=__GENERER__
TSDB_HOST=timescaledb
TSDB_PORT=5432

# --- Redis (conteneur `redis`) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# --- Traccar (conteneur `traccar`, accès interne uniquement) ---
TRACCAR_API_URL=http://traccar:8082/api
TRACCAR_WS_URL=ws://traccar:8082/api/socket
TRACCAR_SERVICE_USER=service@drwintech.com
TRACCAR_SERVICE_PASSWORD='__GENERER__'

# --- JWT ---
ACCESS_TOKEN_LIFETIME_MIN=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Web Push (VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_PATH=infra/vapid_private.pem
VAPID_CONTACT_EMAIL=admin@drwintech.com

# --- Métier ---
DEFAULT_CURRENCY=XOF
PAYMENT_GRACE_DAYS=7
SIM_LOW_BALANCE_THRESHOLD_PERCENT=20

# --- Agrégateurs de paiement ---
PAYMENT_RETURN_BASE=https://fleet.drwintech.com
GOBIPAY_API_KEY=
NOTCHPAY_API_KEY=
FEDAPAY_SECRET_KEY=
FEDAPAY_PUBLIC_KEY=
FEDAPAY_ENVIRONMENT=live
FEDAPAY_WEBHOOK_SECRET=

# --- Superuser initial (créé au 1er démarrage si défini) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@drwintech.com
DJANGO_SUPERUSER_PASSWORD=__GENERER__
